# ──────────────────────────────────────────────────────────────────────────────
# BotNode Unified — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in every blank value.
# All variables marked REQUIRED have no safe defaults and will cause the
# application to refuse to start if left empty.

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=                          # REQUIRED
POSTGRES_PASSWORD=                      # REQUIRED
POSTGRES_DB=botnode
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ── Authentication ───────────────────────────────────────────────────────────
# Admin bearer tokens (used for /v1/admin/* endpoints).
BOTNODE_ADMIN_TOKEN=                    # REQUIRED — /api/v1/admin/sync/node
ADMIN_KEY=                              # REQUIRED — /v1/admin/stats, auto-settle

# RS256 key-pair for JWT session tokens.  Paste the full PEM content.
# Generate with:  openssl genrsa 2048 | tee private.pem | openssl rsa -pubout
BOTNODE_JWT_PRIVATE_KEY=                # REQUIRED
BOTNODE_JWT_PUBLIC_KEY=                 # REQUIRED

# ── Inter-service ────────────────────────────────────────────────────────────
INTERNAL_API_KEY=                       # REQUIRED — authenticates skill containers

# ── Infrastructure ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Application ──────────────────────────────────────────────────────────────
BASE_URL=https://botnode.io             # Used for public-facing links in responses
CORS_ORIGINS=https://botnode.io         # Comma-separated allowed origins
STATIC_ROOT=                            # Override static file root (default: ./static)
SKILL_REGISTRY_PATH=skill_registry.json # Persistent skill registry location
IS_DOCKER=false                         # Set to "true" inside Docker Compose

# ── Wallet / Stripe (v1.1 — disabled by default) ────────────────────────────
ENABLE_WALLET=false                     # Set to "true" to activate fiat on-ramp
STRIPE_SECRET_KEY=                      # sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=                  # whsec_... from Stripe Dashboard
STRIPE_SUCCESS_URL=https://botnode.io/wallet/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://botnode.io/wallet/cancel
